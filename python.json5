{
  python: {
    packageRules: [
      {
        /**
         * Delay PyPI updates briefly, but keep a 48 hour quarantine window.
         *
         * Docs:
         * - Renovate Minimum Release Age
         *   https://docs.renovatebot.com/key-concepts/minimum-release-age/
         * - PyPI supports yanking as a non-destructive alternative to deletion
         *   https://docs.pypi.org/project-management/yanking/
         * - PyPI requires 2FA for all users since 2024-01-01
         *   https://blog.pypi.org/posts/2023-12-13-2fa-enforcement/
         * - PyPI security reports are acknowledged within 48 hours
         *   https://pypi.org/security/
         */
        matchDatasources: ["pypi"],
        internalChecksFilter: "strict",
        minimumReleaseAge: "2 days",
      },
      {
        groupName: "boto3",
        matchPackageNames: ["boto3", "botocore", "boto3-stubs"],
      },
      {
        matchPackageNames: ["typing-extensions"],
        /**
         * Automerge is enabled.
         * Reason: Package Health
         * https://snyk.io/advisor/python/typing-extensions
         */
        automerge: true,
      },
      {
        matchPackageNames: ["mypy"],
        /**
         * Automerge is enabled.
         * Reason: Package Health
         * https://snyk.io/advisor/python/mypy
         */
        automerge: true,
      },
      {
        matchPackageNames: ["pytest"],
        /**
         * Automerge is enabled.
         * Reason: Package Health
         * https://snyk.io/advisor/python/pytest
         */
        automerge: true,
      },
      {
        matchPackageNames: ["ruff"],
        /**
         * Automerge is enabled.
         * Reason: Package Health
         * https://snyk.io/advisor/python/ruff
         */
        automerge: true,
      },
      {
        matchPackageNames: ["black"],
        /**
         * Automerge is enabled.
         * Reason: Package Health
         * https://snyk.io/advisor/python/black
         */
        automerge: true,
      },
      {
        matchPackageNames: ["timevec"],
        /**
         * Automerge is enabled.
         * Reason: I am the author
         */
        automerge: true,
      },
      {
        matchPackageNames: ["cachepot"],
        /**
         * Automerge is enabled.
         * Reason: I am the author
         */
        automerge: true,
      },
      {
        matchPackageNames: ["richset"],
        /**
         * Automerge is enabled.
         * Reason: I am the author
         */
        automerge: true,
      },
      {
        matchPackageNames: ["dict-zip"],
        /**
         * Automerge is enabled.
         * Reason: I am the author
         */
        automerge: true,
      },
      {
        matchPackageNames: ["bamboo-crawler"],
        /**
         * Automerge is enabled.
         * Reason: I am the author
         */
        automerge: true,
      },
      {
        matchPackageNames: ["throttle-controller"],
        /**
         * Automerge is enabled.
         * Reason: I am the author
         */
        automerge: true,
      },
      {
        matchPackageNames: ["tally-token"],
        /**
         * Automerge is enabled.
         * Reason: I am the author
         */
        automerge: true,
      },
    ],
  },
}
